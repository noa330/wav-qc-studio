{
  "name": "wav-qc-studio-electron-frontend",
  "version": "0.1.0",
  "description": "Electron-only React UI shell for WAV QC Studio.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit && electron-vite build",
    "prepare:development-source": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build/prepare-development-source.ps1",
    "prebuild:installer": "npm run prepare:development-source",
    "build:installer": "npm run build && electron-builder --win --config electron-builder.yml",
    "preview": "electron-vite preview",
    "start:built": "electron ."
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  }
}
